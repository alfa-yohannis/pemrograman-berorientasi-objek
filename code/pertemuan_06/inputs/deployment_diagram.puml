@startuml

' Force horizontal layout
left to right direction

' Define nodes and deployed elements
node "Web Server" <<Device>> as WebServer {
  artifact "Web App" <<Artifact>> as WebApp
}

node "Application Server" <<Device>> as AppServer {
  node "JVM" <<ExecutionEnvironment>> as JVM {
    component "Business Logic" <<Component>> as BL
    component "Authentication Module" <<Component>> as Auth
  }
}

node "Database Server" <<Device>> as DBServer {
  database "MySQL Database" <<Database>> as MySQLDB
  artifact "Database Schema" <<Artifact>> as DBSchema
}

' Relationships
WebServer --> AppServer : HTTPS/API Calls
WebApp --> BL : Uses API
BL --> MySQLDB : Reads/Writes Data
Auth --> MySQLDB : Validates Users
DBSchema ..> MySQLDB : Defines schema

' Notes
note right of WebServer
  Hosts and serves the front-end artifact.
end note

note right of AppServer
  Hosts JVM components for business and auth logic.
end note

note right of DBServer
  Hosts the database engine and schema artifact.
end note

@enduml
